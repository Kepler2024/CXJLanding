# ===== SoMark 解析 API =====
# API 密钥，格式 sk-***
SOMARK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# SoMark API 基础地址（不含末尾斜杠），异步接口路径为 {base}/parse/async 与 {base}/parse/async_check
SOMARK_BASE_URL=https://somark.tech/api/v1

# ===== 通用大模型（Claude / Anthropic 兼容）API =====
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Anthropic API 基础地址（官方为 https://api.anthropic.com，可指向兼容网关）
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ===== 模型与服务配置（可选）=====
# OCR / 裁判使用的模型
LLM_MODEL=claude-opus-4-8
# Gradio 监听端口（容器内部端口）
APP_PORT=7860
# 日志目录
LOG_DIR=logs
